{
  "name": "payment-orchestrator",
  "version": "0.1.0",
  "description": "Payment orchestrator with split logic and double-entry ledger for marketplaces",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --project tsconfig.json src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --testPathPattern='src/.*\\.spec\\.ts$' --passWithNoTests",
    "test:int": "jest --testPathPattern='src/.*\\.integration\\.spec\\.ts$' --passWithNoTests --runInBand",
    "test:contract": "jest --testPathPattern='src/.*\\.contract\\.spec\\.ts$' --passWithNoTests",
    "test:e2e": "jest --testPathPattern='src/.*\\.e2e\\.spec\\.ts$' --passWithNoTests --runInBand",
    "test:coverage": "jest --coverage --testPathPattern='src/.*\\.spec\\.ts$'",
    "audit:security": "npm audit --audit-level=high",
    "secrets:check": "secretlint .env.example",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.40.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.47.0",
    "@opentelemetry/sdk-node": "^0.47.0",
    "bullmq": "^5.1.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "opossum": "^8.1.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.4",
    "@commitlint/config-conventional": "^18.4.4",
    "@pact-foundation/pact": "^12.1.0",
    "@secretlint/secretlint-rule-preset-recommend": "^8.1.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.4",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "secretlint": "^8.1.0",
    "supertest": "^6.3.4",
    "testcontainers": "^10.4.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "cross-spawn": "^7.0.5",
    "underscore": "^1.13.7",
    "undici": "^6.21.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings 0",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts",
      "**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "collectCoverageFrom": [
      "src/domain/**/*.ts",
      "src/application/**/*.ts",
      "!src/**/*.spec.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}