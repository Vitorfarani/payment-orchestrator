# ─────────────────────────────────────────────────────────────────────────────
# Payment Orchestrator — variáveis de ambiente
# Copie este arquivo: cp .env.example .env
# Preencha o .env com os valores reais. NUNCA commite o .env.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Aplicação ────────────────────────────────────────────────────────────────

# Ambiente de execução: development | test | production
NODE_ENV=development

# Porta HTTP da API
PORT=3000

# ─── Banco de dados ───────────────────────────────────────────────────────────

# Connection string completa do PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://payment_user:payment_pass@localhost:5432/payment_orchestrator

# Pool de conexões
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────

# Connection string do Redis (cache + filas BullMQ)
REDIS_URL=redis://localhost:6379

# ─── Autenticação ─────────────────────────────────────────────────────────────

# Secret para assinar JWT — mínimo 64 caracteres em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua-por-um-secret-de-64-chars-em-producao

# Tempo de expiração do access token
JWT_ACCESS_EXPIRES_IN=15m

# Tempo de expiração do refresh token
JWT_REFRESH_EXPIRES_IN=7d

# ─── Gateway de pagamento ─────────────────────────────────────────────────────

# Provider ativo: stripe | asaas
PAYMENT_GATEWAY_PROVIDER=stripe

# Stripe (sandbox)
STRIPE_SECRET_KEY=sk_test_substitua_pela_sua_chave
STRIPE_WEBHOOK_SECRET=whsec_substitua_pelo_seu_secret

# Asaas (sandbox) — alternativa ao Stripe
ASAAS_API_KEY=substitua_pela_sua_chave_asaas
ASAAS_WEBHOOK_SECRET=substitua_pelo_seu_secret_asaas
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ─── Observabilidade ──────────────────────────────────────────────────────────

# Nível de log: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Endpoint OTLP do Jaeger para envio de traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Nome do serviço nos traces e métricas
OTEL_SERVICE_NAME=payment-orchestrator

# ─── Segurança ────────────────────────────────────────────────────────────────

# Mascaramento de dados sensíveis em logs
# true em produção e staging, false apenas em desenvolvimento local para debug
MASK_SENSITIVE_DATA=true

# IPs permitidos para o endpoint /metrics do Prometheus (separados por vírgula)
METRICS_ALLOWED_IPS=127.0.0.1,::1

# ─── Configurações de negócio ─────────────────────────────────────────────────

# Schedule de settlement padrão para novos vendedores (dias corridos)
DEFAULT_SETTLEMENT_DAYS=14

# Tempo de retenção de idempotency keys no Redis (segundos)
# 86400 = 24 horas
IDEMPOTENCY_TTL_SECONDS=86400